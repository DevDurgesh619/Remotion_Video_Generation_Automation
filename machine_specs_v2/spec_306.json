{
  "scene": "logo_reveal_animation",
  "duration": 6,
  "fps": 30,
  "canvas": {
    "w": 1920,
    "h": 1080
  },
  "bg": {
    "type": "gradient",
    "from": "#0D1B2A",
    "to": "#1B2838",
    "direction": "to bottom"
  },
  "objects": [
    {
      "id": "logo_mark",
      "shape": "circle",
      "diameter": 280,
      "color": "#FFD700",
      "pos": [
        0,
        0
      ],
      "opacity": 0
    },
    {
      "id": "brand_name",
      "shape": "text",
      "text": {
        "content": "BRAND",
        "fontSize": 48,
        "fontWeight": "bold",
        "textColor": "#FFFFFF"
      },
      "pos": [
        0,
        250
      ],
      "opacity": 0
    },
    {
      "id": "tagline",
      "shape": "text",
      "text": {
        "content": "Your Tagline Here",
        "fontSize": 24,
        "fontWeight": "normal",
        "textColor": "#4ECDC4"
      },
      "pos": [
        0,
        300
      ],
      "opacity": 0
    }
  ],
  "timeline": [
    {
      "target": "logo_mark",
      "time": [
        0,
        2
      ],
      "behavior": "bounce-in"
    },
    {
      "target": "logo_mark",
      "time": [
        0,
        2
      ],
      "glow": {
        "blur": [
          0,
          20
        ],
        "intensity": [
          0,
          1
        ],
        "color": [
          "#FFD700",
          "#FFD700"
        ]
      }
    },
    {
      "target": "brand_name",
      "time": [
        2,
        3
      ],
      "behavior": "slide-in-bottom",
      "params": {
        "distance": 300
      }
    },
    {
      "target": "tagline",
      "time": [
        2.5,
        3.5
      ],
      "behavior": "fade-in"
    },
    {
      "target": "logo_mark",
      "time": [
        2,
        3
      ],
      "behavior": "pulse",
      "params": {
        "amplitude": 0.05,
        "cycles": 1
      }
    },
    {
      "target": "logo_mark",
      "time": [
        4,
        6
      ],
      "glow": {
        "blur": [
          20,
          25
        ],
        "intensity": [
          1,
          0.8
        ],
        "color": [
          "#FFD700",
          "#FFD700"
        ]
      },
      "repeat": "infinite"
    }
  ]
}